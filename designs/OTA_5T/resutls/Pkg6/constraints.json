{
    "align": 
    [
        { "constraint": "PowerPorts",  "ports": ["VDD"] },
        { "constraint": "GroundPorts", "ports": ["VSS"] },

        { "constraint": "PortLocation", "ports": ["VDD"], "location": "TC" },
        { "constraint": "PortLocation", "ports": ["VSS"], "location": "BC" },
        { "constraint": "PortLocation", "ports": ["VIP", "VIN"], "location": "LC" },
        { "constraint": "PortLocation", "ports": ["VOUT"], "location": "RC" },
        { "constraint": "PortLocation", "ports": ["IB"], "location": "BL" },

        { "constraint": "SameTemplate", "instances": ["XM1", "XM2"] },
        { "constraint": "SameTemplate", "instances": ["XM3", "XM4"] },

        { "constraint": "SymmetricBlocks", "direction": "V", "pairs": [["XM1", "XM2"], ["XM3", "XM4"]] }
    ],
    "param_align":
    [
        { 
            "VDD_range": [1.62, 1.98], "VCM_range": [0.81, 0.99], "IB_range": [20, 80], "vi_range": [0.01, 0.1], "fi": 100000, 
            "exact_length": 0.15, "min_width": 0.21, "unit_width_range": [2, 10], "nf_range": [2, 20] 
        },
        { 
            "test_param": ["VDD", "VCM", "IB", "vi", "fi"],
            "circuit_param": ["L1", "L3", "LT", "LB", "W1", "W3", "WT", "WB", "NF1", "NF3", "NFT", "NFB"]
        },
        {
            "same_param": [["WB", "WT"], ["NFB", "NFT"], ["LB", "LT"]]
        }
    ]
}